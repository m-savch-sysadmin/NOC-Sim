{
  "title": "NOC-Sim — Network Overview",
  "uid": "noc-sim-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Interface Status (1 = up, 0 = down)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "ifOperStatus{ifDescr!=\"lo\"}",
          "legendFormat": "{{instance}} - {{ifDescr}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "2": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Inbound Traffic (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(ifHCInOctets{ifDescr!=\"lo\"}[1m])",
          "legendFormat": "{{instance}} - {{ifDescr}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Outbound Traffic (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(ifHCOutOctets{ifDescr!=\"lo\"}[1m])",
          "legendFormat": "{{instance}} - {{ifDescr}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Interface Admin vs Oper Status (table)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "ifOperStatus{ifDescr!=\"lo\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ]
}
